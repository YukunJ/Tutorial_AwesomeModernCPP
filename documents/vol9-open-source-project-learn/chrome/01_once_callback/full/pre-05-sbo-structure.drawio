        <mxCell id="sbo_box" value="" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#2E7D32;strokeWidth=2;fillColor=#E8F5E9;" vertex="1" parent="1">
          <mxGeometry x="100" y="100" width="230" height="130" as="geometry" />
        </mxCell>
        <mxCell id="sbo_title" value="SBO 路径：小对象直接内联存储" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;fontSize=12;fontStyle=1;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="110" y="105" width="210" height="18" as="geometry" />
