        <mxCell id="vtable" value="函数指针 / 虚表指针&lt;br&gt;&lt;i&gt;用于类型擦除的调用分派&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#2E7D32;strokeWidth=1;fillColor=#C8E6C9;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="110" y="130" width="210" height="40" as="geometry" />
        </mxCell>
        <mxCell id="sbo_buf" value="SBO 缓冲区（通常 16-32 字节）&lt;br&gt;&lt;i&gt;小对象直接存这里&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#2E7D32;strokeWidth=1;fillColor=#A5D6A7;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
