        <!-- DMA -->
        <mxCell id="dma" value="DMA 控制器" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#555;strokeWidth=1;fillColor=#F5F5F5;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="50" y="265" width="110" height="40" as="geometry" />
        </mxCell>

        <!-- Flash -->
        <mxCell id="flash" value="Flash 接口" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#555;strokeWidth=1;fillColor=#F5F5F5;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="190" y="265" width="110" height="40" as="geometry" />
        </mxCell>

        <!-- APB1 peripherals -->
        <mxCell id="apb1p" value="TIM2-4, USART2-3&lt;br&gt;I2C1-2, SPI2-3" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#0D47A1;strokeWidth=1;fillColor=#E3F2FD;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
